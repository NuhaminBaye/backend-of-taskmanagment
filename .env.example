# Copy to .env and fill in. Used for local dev.

# === Required ===
# Database (Prisma) - PostgreSQL connection string
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# === Server ===
# Port the NestJS server listens on (default: 5000)
# Flutter app must use this in GRAPHQL_HTTP_ENDPOINT (e.g. http://localhost:5000/graphql)
PORT=5000

# === CORS (for Flutter web) ===
# Backend allows all http://localhost:* and http://127.0.0.1:* by default.
# For a custom frontend origin set:
# FRONTEND_URL=http://localhost:XXXX

# === Optional: dev fallback when no Bearer token is sent ===
# DEFAULT_USER_ID=some-uuid-from-your-db
